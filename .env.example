# ─── Bahía Agents — variables de entorno ───────────────────────────────────────
# Copia este archivo a .env.local y llena los valores. NUNCA subas .env.local.

# Auth (Clerk) — panel interno. Invita usuarios desde el dashboard de Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Supabase (PostgreSQL + pgvector) — usar la SERVICE key (solo en servidor)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Prisma — MISMO Postgres de Supabase (no una segunda DB). Settings → Database:
#   DATABASE_URL = cadena POOLED (pgbouncer, puerto 6543, ?pgbouncer=true) — runtime
#   DIRECT_URL   = cadena DIRECTA (puerto 5432) — migraciones / db pull
# Ver docs/PRISMA_SETUP.md para el runbook de activación.
DATABASE_URL=
DIRECT_URL=

# WhatsApp Business Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
ADMIN_PHONE=

# Meta (App + Marketing/Ads API). META_APP_SECRET se usa para verificar la firma
# del webhook de WhatsApp (X-Hub-Signature-256).
META_APP_ID=
META_APP_SECRET=
META_AD_ACCOUNT_ID=

# Datos de tendencias
PERPLEXITY_API_KEY=
LINKFOXAGENT_API_KEY=

# Cron — protege las rutas /api/cron/*. Vercel Cron envía
# `Authorization: Bearer <CRON_SECRET>`. Genera un valor aleatorio largo.
CRON_SECRET=

# URL pública del despliegue (usada por los crons/webhook para llamadas internas)
NEXT_PUBLIC_URL=
